<?xml version="1.0" encoding="utf-8"?>
<!--
    Text color selector for the round info button. Inverts on focus
    (white circle + dark text) so the glyph stays legible against the
    light fill in the focused state.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:color="@color/brand" />
    <item android:color="@color/text_white" />
</selector>
