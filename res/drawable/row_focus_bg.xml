<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for full-row-focusable switch rows. Empty by default,
    fills brand-tinted on focus / pressed so d-pad navigation is
    obvious across the whole row width (not just at the toggle).
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/row_pressed" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_highlight" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
