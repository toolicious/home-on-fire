<?xml version="1.0" encoding="utf-8"?>
<!--
    State-list background for the target-app chip. Wraps the picker
    icon + app name into one rounded "data field" frame; the fill
    color changes on focus / pressed so the chip itself reads as
    the selectable element instead of the surrounding row.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/row_pressed" />
            <stroke android:width="1dp" android:color="#55FFFFFF" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_highlight" />
            <stroke android:width="1dp" android:color="#55FFFFFF" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1FFFFFFF" />
            <stroke android:width="1dp" android:color="#55FFFFFF" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</selector>
